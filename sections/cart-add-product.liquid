{% comment %}
  <gift-product id="gift-card-product">
    <div>
      {% capture item_html %}
      <div class="item item1">
        <div class="item_inner">
          <div class="item_image">
            <div class="item_image_text text-hidden"><p>Tap to Select</p></div>
          </div>
          <div class="item_title item_price">
            <h4>
              <span>Select Wrapping</span>
            </h4>
          </div>
        </div>
      </div>
      <!-- ====== -->
      <div class="item item2">
        <div class="item_inner">
          <div class="item_image">
            <div class="item_image_text text-hidden"><p>Tap to Select</p></div>
          </div>
          <div class="item_title item_price">
            <h4>
              <span>Select Card</span>
            </h4>
          </div>
        </div>
      </div>
    {% endcapture %}

      {% capture item3 %}
      <div class="item item3">
        <div class="item_inner">
          <div class="item_image">
          <div class="item_image_text text-hidden">
            <p>Tap to Select</p>
          </div>
          </div>
          <div class="item_title item_price">
            <h4>
              <span>Add Message</span>
            </h4>
          </div>
        </div>
      </div>
    {% endcapture %}

      {% if cart.item_count != 0 %}
        <div class="cart_product">
          <div class="container">
            <div class="cart_product_inner">
              <div class="cart_product_title">
                <h3 class="cart_section_title">
                  <span class="main_input">
                    <label for="gift_product_input">
                      <input type="checkbox" id="gift_product_input">
                    </label>
                  </span>
                  <span>🎁 I want to send this as a gift </span>
                </h3>
              </div>
              <div class="cart_product_row">
                <!-- ====== -->

                {% assign number = '' %}
                {% assign item_show = false %}
                {% assign show_html = true %}

                {%- for item in cart.items %}
                  {% for property in item.properties %}
                    {% if property.first == 'Gift Wrap' %}
                      <div
                        class="item item{% if number %}1{% assign number = false  %}{% else %}2{% assign number = true  %}{% endif %}"
                      >
                        <div class="item_inner">
                          <div class="item_image open_drawer">
                            <img src="{{ item.image | image_url  }}" alt="{{ item.image.alt }}" width="" height="">
                          </div>
                          <div class="item_title">
                            <h4>
                              <span>
                                {{ item.title }}
                              </span>
                            </h4>
                          </div>
                        </div>
                      </div>
                      {% assign item_show = true %}
                      {% assign show_html = false %}
                    {% endif %}
                  {% endfor %}
                {% endfor -%}

                {% comment %}
                  {% if cart.item_count != 0 %}
                    {%- for item in cart.items %}
                      {% if item.properties != empty %}
                        {% for property in item.properties %}
                          {% if property.first == 'Gift Wrap' %}
                            <div
                              class="item item{% if number %}1{% assign number = false  %}{% else %}2{% assign number = true  %}{% endif %}"
                            >
                              <div class="item_inner">
                                <div class="item_image">
                                  <img src="{{ item.image | image_url  }}" alt="{{ item.image.alt }}" width="" height="">
                                </div>
                                <div class="item_title">
                                  <h4>
                                    <span>
                                      {{ item.title }}
                                    </span>
                                  </h4>
                                </div>
                              </div>
                            </div>
                            {% assign item_show = true %}
                          {% endif %}
                        {% else -%}
                          {{ item_html }}
                          {{ item3 }}
                        {% endfor %}
                      {% else -%}
                        {% comment %} {% if item.properties == empty %} {% endcomment %}
                          {{ item_html }}
                          {{ item3 }}
                          {% break %}
                        {% comment %} {% endif %} {% endcomment %}
                      {% endif %}
                    {% endfor -%}

                  {% else -%}
                    {{ item_html }}
                    {{ item3 }}
                  {% endif %}
                {% endcomment %}
                {% if show_html %}
                  {{ item_html }}
                  {{ item3 }}
                {% endif %}
                <!-- ====== -->
                {% if item_show %}
                  <div class="item item3">
                    <div class="item_inner">
                      <div class="item_image">
                        {% for attribute in cart.attributes %}
                          {% if attribute.last != blank %}
                            {% if attribute.first == 'gift-note' %}
                              <div class="item_image_text">
                                {% comment %} <p>Tap to Select</p> {% endcomment %}
                                <p>{{ attribute.last }}</p>
                              </div>
                            {% endif %}
                          {% endif %}
                        {% endfor %}
                      </div>
                      <div class="item_title item_price">
                        <h4>
                          <span>Add Message</span>
                        </h4>
                      </div>
                    </div>
                  </div>
                {% endif %}

                <!-- ====== -->
              </div>
            </div>
          </div>
        </div>

        <div class="cart_gift_drawer ">
          <div class="cart_gift_drawer_inner">
            <!-- Wrapping -->
            <div class="wrapping_product">
              <div class="drawer_title">
                <div class="drawer_title_inner">
                  <div class="title_text">
                    <span>Select Wrapping</span>
                  </div>
                  <div class="cart_gift_drawer_close">
                    <a role="link" aria-disabled="true" class="_close"><button class="close-btn">&times;</button></a>
                  </div>
                </div>
              </div>
              <div class="gift_drawer_product">
                <div id="cart-notification-product" class="cart-notification-product">
                  {% for product in section.settings.product_wrapping %}
                    <div
                      class="mini-cart-item"
                      style="display: flex;justify-content: space-between;padding: 15px 0 12px;border-bottom: 1px solid #70707063;"
                    >
                      <div
                        class="m-cart-pr-details"
                        style="
                          width: 177px;
                          padding-right: 15px;
                          display: flex;
                          flex-direction: column;
                          justify-content: space-around;
                        "
                      >
                        <div class="item_tile">
                          <h3>{{ product.title }}</h3>
                          <h5>
                            Price: <span>{{ product.price | money }}</span>
                          </h5>
                        </div>
                        <div class="item_addbutton">
                          <button
                            class="gift_product_add button button--full-width button--secondary btn-bg-border"
                            data-title="{{ product.title | escape }}"
                            data-image="{{ product.featured_image | image_url  }}"
                            data-id="{{ product.selected_or_first_available_variant.id }}"
                          >
                            <span>
                              {%- if product.selected_or_first_available_variant.available -%}
                                Add Product
                              {%- else -%}
                                {{ 'products.product.sold_out' | t }}
                              {%- endif -%}
                            </span>
                            {% render 'icons', icon: 'right_arrow' %}
                          </button>
                        </div>
                      </div>
                      <div class="m-cart-pr-image">
                        <a href="{{ product.url }}">
                          <img
                            src="{{ product.featured_image | image_url }}"
                            alt=""
                            width=""
                            height=""
                            style="width:111px;"
                          >
                        </a>
                      </div>
                    </div>
                  {% endfor %}
                </div>
                <div class="drawer_next">
                  <button
                    class="drawer_next_button button button--full-width button--secondary btn-bg-border"
                    style="width:100%"
                  >
                    Next
                  </button>
                </div>
              </div>
            </div>

            <!-- Cart -->
            <div class="cart_gift_product hidden_item">
              <div class="drawer_title">
                <div class="drawer_title_inner">
                  <div class="title_text">
                    <div class="drawer_back_button">
                      <svg
                        width="24"
                        height="23"
                        viewBox="0 0 24 23"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M15 18l-6-6 6-6"/>
                      </svg>
                    </div>
                    <span>Select Card</span>
                  </div>
                  <div class="cart_gift_drawer_close">
                    <a role="link" aria-disabled="true" class="_close"><button class="close-btn">&times;</button></a>
                  </div>
                </div>
              </div>
              <div class="gift_drawer_product">
                <div id="cart-notification-product" class="cart-notification-product">
                  {% for product in section.settings.product_card %}
                    <div
                      class="mini-cart-item"
                      style="display: flex;justify-content: space-between;padding: 15px 0 12px;border-bottom: 1px solid #70707063;"
                    >
                      <div
                        class="m-cart-pr-details"
                        style="
                          width: 177px;
                          padding-right: 15px;
                          display: flex;
                          flex-direction: column;
                          justify-content: space-around;
                        "
                      >
                        <div class="item_tile">
                          <h3>{{ product.title }}</h3>
                          <h5>
                            Price: <span>{{ product.price | money }}</span>
                          </h5>
                        </div>
                        <div class="item_addbutton">
                          <button
                            class="gift_product_add button button--full-width button--secondary btn-bg-border"
                            data-title="{{ product.title | escape }}"
                            data-image="{{ product.featured_image | image_url  }}"
                            data-id="{{ product.selected_or_first_available_variant.id }}"
                          >
                            <span>
                              {%- if product.selected_or_first_available_variant.available -%}
                                Add Product
                              {%- else -%}
                                {{ 'products.product.sold_out' | t }}
                              {%- endif -%}
                            </span>
                            {% render 'icons', icon: 'right_arrow' %}
                          </button>
                        </div>
                      </div>
                      <div class="m-cart-pr-image">
                        <a href="{{ product.url }}">
                          <img
                            src="{{ product.featured_image | image_url }}"
                            alt=""
                            width=""
                            height=""
                            style="width:111px;"
                          >
                        </a>
                      </div>
                    </div>
                  {% endfor %}
                </div>
                <div class="drawer_next">
                  <button
                    class="drawer_next_button button button--full-width button--secondary btn-bg-border"
                    style="width:100%"
                  >
                    Next
                  </button>
                </div>
              </div>
            </div>

            <!-- Message -->
            <div class="gift_message hidden_item">
              <div class="drawer_title">
                <div class="drawer_title_inner">
                  <div class="title_text">
                    <div class="drawer_back_button">
                      <svg
                        width="24"
                        height="23"
                        viewBox="0 0 24 23"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M15 18l-6-6 6-6"/>
                      </svg>
                    </div>
                    <span>Add Message</span>
                  </div>
                  <div class="cart_gift_drawer_close">
                    <a role="link" aria-disabled="true" class="_close"><button class="close-btn">&times;</button></a>
                  </div>
                </div>
              </div>
              <div class="gift_drawer_product">
                <div
                  class="gift_drawer_message"
                  style="
                    padding:15px 0;display: flex;
                    flex-direction: column;
                    gap: 15px;
                  "
                >
                  <input type="text" placeholder="To: (Optional)" name="to_field" class="input_to_field">
                  <textarea
                    maxlength="200"
                    rows="6"
                    placeholder="Type Your Message & Express Your Feelings"
                    class="gift_textarea_mess"
                  ></textarea>
                  <p class="gift_textarea_text" style="text-transform: capitalize;">maximum 200 characters allowed*</p>
                  <input type="text" placeholder="From: (Optional)" name="from_field" class="input_from_field">
                </div>
                <form action="/cart/add" method="post" novalidate>
                  <div class="drawer_next gift_mess_button">
                    {% comment %} <input type="checkbox" name="attributes[gift-wrapping]" id="gift-wrapping" value="yes" {% if cart.attributes["gift-wrapping"] == "yes" %} checked{% endif %}> {% endcomment %}
                    <button
                      type="submit"
                      name="update"
                      class="add_gift_product button button--full-width button--secondary btn-bg-border"
                      style="width:100%"
                    >
                      Finish
                    </button>
                  </div>
                </form>
              </div>
            </div>
          </div>
        </div>
      {% endif %}
    </div>
  </gift-product>
{% endcomment %}

