            </form>
          </div>
        </div>
      </div>
    </div>
  {% endif %}
</div>

{% javascript %}
  // item 1 // item 2
  var productid1 = '';
  var productid2 = '';
  function addproduct() {
    const addbutton = document.querySelectorAll('.gift_product_add');
    if (addbutton) {
      addbutton.forEach((element) => {
        element.addEventListener('click', function (event) {
          event.preventDefault();
          console.log('THis is element :: ', element.classList.add);
          const parentDiv = event.target.closest('.wrapping_product');
          // console.log('parentDiv :: ', parentDiv);
          var next_btn = element.closest('.mini-cart-item');

          var image = element.dataset.image;
          var title = element.dataset.title;

          if (parentDiv) {
            productid1 = element.dataset.id;
            // console.log('this is id :: ', productid1);
            document.querySelector('.item1 .item_image').innerHTML = `<img src=${image} alt=${title}>`;
            document.querySelector('.item1 .item_title h4 span').innerHTML = title;

            document.querySelector('.item2 .item_image .item_image_text').classList.remove('text-hidden');
            document.querySelector('.item2 .item_image').classList.add('open_drawer');
          } else {
            productid2 = element.dataset.id;
            // console.log('this is id :: ', productid2);
            document.querySelector('.item2 .item_image').innerHTML = `<img src=${image} alt=${title}>`;
            document.querySelector('.item2 .item_title h4 span').innerHTML = title;

            document.querySelector('.item3 .item_image .item_image_text').classList.remove('text-hidden');
            document.querySelector('.item3 .item_image').classList.add('open_drawer');
          }

          if (next_btn) {
            next_btn.classList.add('active-product');
          }
        });
      });
    }
  }
  addproduct();

  // Next Button
  function nextbtn() {
    const nextbtn = document.querySelectorAll('.drawer_next_button');
    if (nextbtn) {
      nextbtn.forEach((element) => {
        element.addEventListener('click', function (event) {
          event.preventDefault();
          const parentDiv = event.target.closest('.wrapping_product');
          console.log('THis is parent DIV  :: ', parentDiv);
          if (parentDiv) {
            document.querySelector('.wrapping_product').classList.add('hidden_item');
            document.querySelector('.cart_gift_product').classList.remove('hidden_item');
            var demo = element.closest('.mini-cart-item');
            console.log('this is demo :: ', demo);
          } else {
            document.querySelector('.cart_gift_product').classList.add('hidden_item');
            document.querySelector('.gift_message').classList.remove('hidden_item');
          }
        });
      });
    }
  }
  nextbtn();

  // Back Button
  function back_btn() {
    const back_button = document.querySelectorAll('.drawer_back_button');
    if (back_button) {
      back_button.forEach((element) => {
        element.addEventListener('click', function (e) {
          e.preventDefault();
          const parentDiv = e.target.closest('.cart_gift_product');
          // console.log('ParentDiv :: ', parentDiv);
          if (parentDiv) {
            document.querySelector('.cart_gift_product').classList.add('hidden_item');
            document.querySelector('.wrapping_product').classList.remove('hidden_item');
          } else {
            document.querySelector('.gift_message').classList.add('hidden_item');
            document.querySelector('.cart_gift_product').classList.remove('hidden_item');
          }
        });
      });
    }
  }
  back_btn();

  // Item 3 Text
  function item3_text() {
    const gettext = document.querySelector('.gift_textarea_mess');
    if (gettext) {
      gettext.addEventListener('input', function (event) {
        const currentText = event.target.value;
        // console.log();
        const targetElement = document.querySelector('.item3 .item_image .item_image_text p');
        if (targetElement) {
          targetElement.textContent = currentText;
        }
        if (currentText.length == 0) {
          targetElement.textContent = `Tap to Select`;
        }
      });
    }
  }
  item3_text();

  // Add To Cart Button
  function add_to_cart() {
    const addtocart = document.querySelector('.add_gift_product');
    if (addtocart) {
      addtocart.addEventListener('click', function (e) {
        e.preventDefault();
        const selectedProducts = getSelectedProductsData();

        if (selectedProducts.length === 0) {
          alert('Please select at least one product.');
          return;
        }

        var formData = {
          items: selectedProducts,
          attributes: { 'gift-wrapping': true },
        };

        var notetext = document.querySelector('.gift_textarea_mess');
        var input_to_field = document.querySelector('.input_to_field');
        var input_from_field = document.querySelector('.input_from_field');

        if (input_to_field.value) {
          formData.attributes['to_input'] = input_to_field.value;
        }
        if (notetext.value) {
          formData.attributes['gift-note'] = notetext.value;
        }
        if (input_from_field.value) {
          formData.attributes['from_input'] = input_from_field.value;
        }

        // console.log('formData : ', formData);
        // fetch('/cart/add.js', {

        const sectionsToUpdate = ['main-cart'];
        const sectionsUrl = '/cart';
        fetch(`/cart/add.js?sections=${sectionsToUpdate.join(',')}&sections_url=${sectionsUrl}`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(formData),
        })
          .then((response) => response.json())
          .then((data) => {
            // console.log('Success:', data);
            document.getElementById('main_cart_page').innerHTML = data.sections['main-cart'];
            document.querySelector('.cart_gift_drawer').classList.remove('active-cart');

            setTimeout(() => {
              document.querySelector('.wrapping_product').classList.remove('hidden_item');
              document.querySelector('.cart_gift_product').classList.add('hidden_item');
              document.querySelector('.gift_message').classList.add('hidden_item');

              // open_drawer();
            }, 500);
          })
          .catch((error) => {
            console.error('Error:', error);
          });
      });
    }
  }
  add_to_cart();

  function getSelectedProductsData() {
    const items = [];
    items.push({ id: productid1, quantity: 1, properties: { 'Gift Wrap': true } });
    items.push({ id: productid2, quantity: 1, properties: { 'Gift Wrap': true } });
    // console.log('THis is items :: ', items);
    return items;
  }

  // Remove Cart
  function removecart_item() {
    fetch('/cart.js')
      .then((response) => response.json())
      .then((cart) => {
        console.log('THis is cart Items :: ', cart.item_count);

        const itemsToRemove = [];
        cart.items.forEach((item) => {
          if (item.properties && item.properties['Gift Wrap'] === true) {
            itemsToRemove.push(item.id);
          }
        });

        var updateData = {};
        itemsToRemove.forEach(function (key) {
          updateData[key] = 0;
        });
        // const sectionsToUpdate = ['main-cart','cart-add-product'];
        const sectionsToUpdate = ['main-cart'];
        const sectionsUrl = '/cart';
        fetch(`/cart/update.js?sections=${sectionsToUpdate.join(',')}&sections_url=${sectionsUrl}`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            updates: updateData,
            attributes: {
              'gift-wrapping': false,
              'gift-note': '',
              to_input: '',
              from_input: '',
            },
          }),
        })
          .then((response) => response.json())
          .then((data) => {
            console.log('Cart updated:', data);
            document.getElementById('main_cart_page').innerHTML = data.sections['main-cart'];
            // document.getElementById('gift-card-product').innerHTML = data.sections['cart-add-product'];

            console.log('this is ONE');
            document.querySelector(
              '.item1 .item_image'
            ).innerHTML = `<div class="item_image_text text-hidden"><p>Tap to Select</p></div>`;
            document.querySelector('.item1 .item_title h4 span').innerHTML = `Select Wrapping`;

            document.querySelector(
              '.item2 .item_image'
            ).innerHTML = `<div class="item_image_text text-hidden"><p>Tap to Select</p></div>`;
            document.querySelector('.item2 .item_title h4 span').innerHTML = `Select Card`;

            document.querySelector(
              '.item3 .item_image'
            ).innerHTML = `<div class="item_image_text text-hidden"><p>Tap to Select</p></div>`;

            document.querySelector('.item2 .item_image').classList.remove('open_drawer');
            document.querySelector('.item3 .item_image').classList.remove('open_drawer');
            document.querySelector('.item1 .item_image .item_image_text').classList.add('text-hidden');

            document.querySelector('.cart_gift_drawer').classList.remove('active-cart');

            if (data.item_count == 0) {
              document.querySelector('#gift-card-product').style.display = 'none';
            }
          })
          .catch((error) => {
            console.error('Error updating cart:', error);
          });
      });
  }

  document.addEventListener('DOMContentLoaded', (event) => {
    const myCheckbox = document.getElementById('gift_product_input');
    const savedState = localStorage.getItem('myCheckState');
    if (myCheckbox) {
      if (savedState !== null) {
        myCheckbox.checked = savedState === 'true';
      }
    }
  });

  document.addEventListener('DOMContentLoaded', (event) => {
    const product_cart = document.querySelectorAll('.item_image');
    // console.log('THis is Product Card :: ', product_cart);
    if (product_cart) {
      product_cart.forEach((element) => {
        element.addEventListener('click', function (e) {
          e.preventDefault();
          console.log(':: 111 ::', e.target);

          var item_image = e.target.classList.contains('item_image') ? e.target : e.target.closest('.item_image');
          var parentDiv1 = e.target.closest('.cart_product_inner .cart_product_row .item2');
          var parentDiv2 = e.target.closest('.cart_product_inner .cart_product_row .item3');

          if (parentDiv1) {
            document.querySelector('.wrapping_product').classList.add('hidden_item');
            document.querySelector('.cart_gift_product').classList.remove('hidden_item');
          } else if (parentDiv2) {
            document.querySelector('.wrapping_product').classList.add('hidden_item');
            document.querySelector('.cart_gift_product').classList.add('hidden_item');
            document.querySelector('.gift_message').classList.remove('hidden_item');
          }
          if (item_image.classList.contains('open_drawer')) {
            document.querySelector('.cart_gift_drawer').classList.add('active-cart');
          }
          // addproduct();
          // nextbtn();
          // back_btn();
          // item3_text();
          // add_to_cart();
        });
      });
    }

    const myCheckbox1 = document.getElementById('gift_product_input');
    if (myCheckbox1) {
      myCheckbox1.addEventListener('change', function () {
        localStorage.setItem('myCheckState', this.checked);
        if (this.checked) {
          console.log(':: 111111 ::');
          document.querySelector('.item1 .item_image').classList.add('open_drawer');
          document.querySelector('.item1 .item_image .item_image_text').classList.remove('text-hidden');
        } else {
          console.log('22222');
          document.querySelector('.item1 .item_image').classList.remove('open_drawer');
          removecart_item();
        }
      });
    }

    // Close Button
    const product_cart_close = document.querySelectorAll('.cart_gift_drawer_close');
    product_cart_close.forEach((element) => {
      element.addEventListener('click', function (e) {
        e.preventDefault();
        console.log(':: 222 ::');
        document.querySelector('.cart_gift_drawer').classList.remove('active-cart');

        setTimeout(() => {
          document.querySelector('.wrapping_product').classList.remove('hidden_item');
          document.querySelector('.cart_gift_product').classList.add('hidden_item');
          document.querySelector('.gift_message').classList.add('hidden_item');
        }, 300);
      });
    });
  });
{% endjavascript %}

