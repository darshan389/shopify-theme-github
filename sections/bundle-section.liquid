<div class="custom-product-section">
  <div class="container">
    {% assign collection = section.settings.collection_one %}
    {% assign collection1 = section.settings.collection_two %}

    <div class="product_img">
      <div class="product_img__group product_img__group--one">
        {% if collection != blank %}
          {% for product in collection.products limit: 4 %}
            <div
              class="product-image-item{% if forloop.first %} is-active{% endif %}"
              data-handle="{{ product.handle }}"
              {% unless forloop.first %}
                style="display:none;"
              {% endunless %}
            >
              <img
                class="main-product-image"
                src="{{ product.featured_image | image_url: width: 500 }}"
                alt="{{ product.title }}"
                width=""
                height=""
              >
 
               {% comment %} color -> variant image map, used by JS to swap the image on swatch click {% endcomment %}
              <script type="application/json" class="color-image-map">
                {
                  {% for option in product.options_with_values %}
                    {% if option.name == 'Color' %}
                      {% assign idx = option.position | minus: 1 %}
                      {% for value in option.values %}
                        {% assign variant_image = '' %}
                        {% for variant in product.variants %}
                          {% if variant.options[idx] == value and variant_image == blank %}
                            {% assign variant_image = variant.featured_image | image_url: width: 500 %}
                          {% endif %}
                        {% endfor %}
                        {% if variant_image == blank %}
                          {% assign variant_image = product.featured_image | image_url: width: 500 %}
                        {% endif %}
                        "{{ value | escape }}": "{{ variant_image }}"{% unless forloop.last %},{% endunless %}
                      {% endfor %}
                    {% endif %}
                  {% endfor %}
                }
              </script>
            </div>
          {% endfor %}
        {% endif %}
      </div>

      <div class="product_img__group product_img__group--two">
        {% if collection1 != blank %}
          {% for product in collection1.products limit: 4 %}
            <div
              class="product-image-item product-image-item--two{% if forloop.first %} is-active{% endif %}"
              data-handle="{{ product.handle }}"
              {% unless forloop.first %}
                style="display:none;"
              {% endunless %}
            >
              <img
                class="main-product-image"
                src="{{ product.featured_image | image_url: width: 500 }}"
                alt="{{ product.title }}"
                width=""
                height=""
              >
            </div>
          {% endfor %}
        {% endif %}
      </div>
    </div>

    <div class="product-grid">
      {% if collection != blank %}
        {% for product in collection.products limit: 4 %}
          <div class="product-card{% if forloop.first %} is-active{% endif %}" data-handle="{{ product.handle }}">
            <img
              src="{{ product.featured_image | image_url: width: 500 }}"
              alt="{{ product.title }}"
              width=""
              height=""
            >
            <h4>{{ product.title }}</h4>
            <button
              type="button"
              class="button button--full-width button--secondary btn-bg-border select-product-btn"
              data-handle="{{ product.handle }}"
            >
              Add Bundle
            </button>
          </div>
        {% endfor %}
      {% endif %}
    </div>

    <div class="product-grid product-grid-2" style="margin: 20px 0 0 0;">
      {% if collection1 != blank %}
        {% for product in collection1.products limit: 4 %}
          <div
            class="product-card product-card--two{% if forloop.first %} is-active{% endif %}"
            data-handle="{{ product.handle }}"
          >
            <img
              src="{{ product.featured_image | image_url: width: 500 }}"
              alt="{{ product.title }}"
              width=""
              height=""
            >
            <h4>{{ product.title }}</h4>
            <button
              type="button"
              class="button button--full-width button--secondary btn-bg-border select-product-btn select-product-btn--two"
              data-handle="{{ product.handle }}"
            >
              Add Bundle
            </button>
          </div>
        {% endfor %}
      {% endif %}
    </div>

    <div class="variant-picker">
      {% if collection != blank %}
        {% for product in collection.products limit: 4 %}
          <div
            class="color-swatches"
            data-handle="{{ product.handle }}"
            {% unless forloop.first %}
              style="display:none;"
            {% endunless %}
          >
            {% for option in product.options_with_values %}
              {% if option.name == 'Color' %}
                <span class="color-swatches__label">Selected Color : {{ option.selected_value }}</span>
                <div class="color-swatches__list">
                  {% for value in option.values %}
                    <span
                      class="color-item{% if value == option.selected_value %} is-selected{% endif %}"
                      style="background-color: {{ value }};"
                      title="{{ value }}"
                    ></span>
                  {% endfor %}
                </div>
              {% endif %}
            {% endfor %}
          </div>
        {% endfor %}
      {% endif %}
    </div>

    <div class="add_to_cart_button">
      <button class="button button--full-width button--secondary btn-bg-border select-product-btn">Add To Cart</button>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Bundle Product",
  "settings": [
    {
      "type": "collection",
      "id": "collection_one",
      "label": "Add First Collection"
    },
    {
      "type": "collection",
      "id": "collection_two",
      "label": "Add Two Collection"
    }
  ],
  "presets": [
    {
      "name": "Bundle Product"
    }
  ]
}
{% endschema %}

{% stylesheet %}
  /* =========================
    Custom Product Section
    ========================= */

    .custom-product-section {
        width: 100%;
    }

    .custom-product-section .container {
        width: 100%;
        max-width: 1000px;
        margin: 0 auto;
        padding: 40px 15px;
    }

    /* Big selected-product images (side by side) */
    .custom-product-section .product_img {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 20px;
        margin-bottom: 20px;
        border: 1px solid #b39f97;
        border-radius: 15px;
        padding: 15px;
        flex-wrap: wrap;
        position: relative;
    }

    .custom-product-section .product_img__group {
        flex: 1 1 220px;
        display: flex;
        justify-content: center;
        position: absolute;
    }

    .custom-product-section .product-image-item img {
        display: block;
        width: 100%;
        max-width: 300px;
        height: auto;
        border-radius: 12px;
        object-fit: cover;
        margin: 0 auto;
    }

    .custom-product-section .product-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 15px;
        border: 1px solid #b39f97;
        padding: 15px;
        border-radius: 15px;
    }

    .custom-product-section .product-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        cursor: pointer;
    }

    .custom-product-section .product-card img {
        display: block;
        width: 100%;
        height: auto;
        border-radius: 8px;
        object-fit: cover;
        width: 150px;
    }

    .custom-product-section .product-card h4 {
        margin: 16px 0 10px;
        font-size: 16px;
        font-weight: 600;
        line-height: 1.3;
        color: #222;
    }

    .custom-product-section .product-card p {
        margin: 0;
        font-size: 16px;
        line-height: 1.6;
        color: #666;
    }

    .custom-product-section .product-card.is-active {
        outline: 2px solid #6e6f70ff;
        outline-offset: 4px;
        border-radius: 8px;
    }

    /* Tablet */
    @media (max-width: 991px) {
        .custom-product-section .product-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    /* Mobile */
    @media (max-width: 576px) {
        .custom-product-section .product-grid {
            grid-template-columns: 1fr;
            gap: 20px;
        }

        .custom-product-section .product-card h3 {
            font-size: 20px;
        }

        .custom-product-section .product-card p {
            font-size: 15px;
        }
    }

    /* =========================
       Variant Picker / Swatches
       ========================= */

    .custom-product-section .variant-picker {
        margin-top: 20px;
        padding: 20px;
        border: 1px solid #b39f97;
        border-radius: 12px;
    }

    .custom-product-section .color-swatches {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .custom-product-section .color-swatches__label {
        font-size: 15px;
        font-weight: 600;
        color: #222;
    }

    .custom-product-section .color-swatches__list {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .custom-product-section .color-item {
        display: inline-block;
        width: 32px;
        height: 32px;
        border: 1px solid #ddd;
        border-radius: 50%;
        cursor: pointer;
        box-shadow: rgba(0, 0, 0, 0.17) 0px -23px 25px 0px inset, rgba(0, 0, 0, 0.15) 0px -36px 30px 0px inset, rgba(0, 0, 0, 0.1) 0px -79px 40px 0px inset, rgba(0, 0, 0, 0.06) 0px 2px 1px, rgba(0, 0, 0, 0.09) 0px 4px 2px, rgba(0, 0, 0, 0.09) 0px 8px 4px, rgba(0, 0, 0, 0.09) 0px 16px 8px, rgba(0, 0, 0, 0.09) 0px 32px 16px;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .custom-product-section .color-item:hover {
        transform: scale(1.1);
    }

    .custom-product-section .color-item.is-selected {
        border-color: #2da9ff;
        box-shadow: 0 0 0 2px #2da9ff;
    }

    @media (max-width: 576px) {
        .custom-product-section .variant-picker {
            padding: 15px;
        }

        .custom-product-section .color-item {
            width: 28px;
            height: 28px;
        }
    }


  .add_to_cart_button {
    margin: 20px 0;
    width: 100%;
    text-align: center;
  }
  .add_to_cart_button button{
    width: 500px;
    padding: 6px 0;
    border-radius: 10px;
  }

{% endstylesheet %}

<script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.custom-product-section').forEach(function (section) {
      var cards = section.querySelectorAll('.product-card:not(.product-card--two)');
      var cardsTwo = section.querySelectorAll('.product-card--two');
      var swatchGroups = section.querySelectorAll('.color-swatches');
      var imageItems = section.querySelectorAll('.product-image-item:not(.product-image-item--two)');
      var imageItemsTwo = section.querySelectorAll('.product-image-item--two');

      function selectProduct(handle) {
        cards.forEach(function (card) {
          card.classList.toggle('is-active', card.dataset.handle === handle);
        });
        swatchGroups.forEach(function (group) {
          group.style.display = group.dataset.handle === handle ? '' : 'none';
        });
        imageItems.forEach(function (item) {
          item.style.display = item.dataset.handle === handle ? '' : 'none';
        });
      }

      function selectProductTwo(handle) {
        cardsTwo.forEach(function (card) {
          card.classList.toggle('is-active', card.dataset.handle === handle);
        });
        imageItemsTwo.forEach(function (item) {
          item.style.display = item.dataset.handle === handle ? '' : 'none';
        });
      }

      cards.forEach(function (card) {
        card.addEventListener('click', function (e) {
          var btn = e.target.closest('.select-product-btn');
          if (btn) {
            e.preventDefault();
          }
          selectProduct(card.dataset.handle);
        });
      });

      cardsTwo.forEach(function (card) {
        card.addEventListener('click', function (e) {
          var btn = e.target.closest('.select-product-btn');
          if (btn) {
            e.preventDefault();
          }
          selectProductTwo(card.dataset.handle);
        });
      });

      // color swatch click -> update selected swatch + swap the (first) product image
      swatchGroups.forEach(function (group) {
        var handle = group.dataset.handle;
        var label = group.querySelector('.color-swatches__label');
        var imageItem = section.querySelector(
          '.product-image-item[data-handle="' + handle + '"]:not(.product-image-item--two)'
        );
        var mapScript = imageItem ? imageItem.querySelector('.color-image-map') : null;
        var colorMap = {};

        if (mapScript) {
          try {
            colorMap = JSON.parse(mapScript.textContent);
          } catch (err) {
            colorMap = {};
          }
        }

        group.querySelectorAll('.color-item').forEach(function (swatch) {
          swatch.addEventListener('click', function () {
            var color = swatch.getAttribute('title');

            group.querySelectorAll('.color-item').forEach(function (s) {
              s.classList.remove('is-selected');
            });
            swatch.classList.add('is-selected');

            if (label) {
              label.textContent = 'Selected Color : ' + color;
            }

            if (imageItem && colorMap[color]) {
              var img = imageItem.querySelector('.main-product-image');
              if (img) {
                img.src = colorMap[color];
              }
            }
          });
        });
      });
    });
  });
</script>
