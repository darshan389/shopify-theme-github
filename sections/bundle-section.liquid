{% comment %} <div class="custom-product-section">
  <div class="container">
    <div class="product-grid">
      {% assign collection = section.settings.collection_one %}

      {% if collection != blank %}
        {% for product in collection.products limit: 4 %}
          <div class="product-card">
            <a href="{{product.url }}" class="link">
              <img
                src="{{ product.featured_image | image_url: width: 500 }}"
                alt="{{ product.title }}"
                width=""
                height=""
              >
            </a>
            <h4>{{ product.title }}</h4>
            <button class="button button--full-width button--secondary btn-bg-border">Add Bundle</button>
          </div>
          {% assign product_handle = product.handle %}
        {% endfor %}
      {% endif %}
    </div>
    {% assign product = all_products[product_handle] %}
    {% if product != blank %}
      {% for option in product.options_with_values %}
        {% if option.name == 'Color' %}
          <div class="color-swatches">
            {% for value in option.values %}
              <span
                class="color-item"
                style="background-color: {{ value }};"
              >
              </span>
            {% endfor %}
          </div>
        {% endif %}
      {% endfor %}
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Bundle Product",
  "settings": [
    {
      "type": "collection",
      "id": "collection_one",
      "label": "Add First Collection"
    },
    {
      "type": "collection",
      "id": "collection_two",
      "label": "Add Two Collection"
    }
  ],
  "presets": [
    {
      "name": "Bundle Product"
    }
  ]
}
{% endschema %}

{% stylesheet %}
      /* =========================
        Custom Product Section
        ========================= */

        .custom-product-section {
            width: 100%;
        }

        .custom-product-section .container {
            width: 100%;
            max-width: 1000px;
            margin: 0 auto;
            padding: 40px 15px;
        }

        .custom-product-section .product-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 15px;
            border: 1px solid #b39f97;
            padding: 15px 0;
            border-radius: 15px;
        }

        .custom-product-section .product-card {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
        }

        .custom-product-section .product-card img {
            display: block;
            width: 100%;
            height: auto;
            border-radius: 8px;
            object-fit: cover;
            width: 150px;
        }

        .custom-product-section .product-card h4 {
            margin: 16px 0 10px;
            font-size: 16px;
            font-weight: 600;
            line-height: 1.3;
            color: #222;
        }

        .custom-product-section .product-card p {
            margin: 0;
            font-size: 16px;
            line-height: 1.6;
            color: #666;
        }

        /* Tablet */
        @media (max-width: 991px) {
            .custom-product-section .product-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        /* Mobile */
        @media (max-width: 576px) {
            .custom-product-section .product-grid {
                grid-template-columns: 1fr;
                gap: 20px;
            }

            .custom-product-section .product-card h3 {
                font-size: 20px;
            }

            .custom-product-section .product-card p {
                font-size: 15px;
            }
        }



        .color-item {
      display: inline-block;
      width: 30px;
      height: 30px;
      border: 1px solid #ddd;
      border-radius: 50%;
  }
        .variant-picker {
        margin-top: 20px;
    }

    .variant-picker__title {
        margin-bottom: 20px;
        font-size: 16px;
        font-weight: 600;
    }

    .variant-picker__list {
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
    }

    .variant-picker__item {
        cursor: pointer;
        text-align: center;
    }

    .variant-picker__item input {
        display: none;
    }

    .variant-picker__item img {
        display: block;
        width: 70px;
        height: 70px;
        object-fit: cover;
        border: 2px solid #ddd;
        transition: .3s;
    }

    .variant-picker__name {
        display: block;
        margin-top: 8px;
        font-size: 13px;
    }

    .variant-picker__item input:checked + img {
        border-color: #2da9ff;
        box-shadow: 0 0 0 2px #2da9ff;
    }
{% endstylesheet %} {% endcomment %}


<div class="custom-product-section">
  <div class="container">
    <div class="product-grid">
      {% assign collection = section.settings.collection_one %}

      {% if collection != blank %}
        {% for product in collection.products limit: 4 %}
          <div class="product-card{% if forloop.first %} is-active{% endif %}" data-handle="{{ product.handle }}">
            <a href="{{ product.url }}" class="link">
              <img
                src="{{ product.featured_image | image_url: width: 500 }}"
                alt="{{ product.title | escape }}"
                width="500"
                height="{{ 500 | divided_by: product.featured_image.aspect_ratio | default: 500 }}"
                loading="lazy"
              >
            </a>
            <h4>{{ product.title }}</h4>
            <button
              type="button"
              class="button button--full-width button--secondary btn-bg-border select-product-btn"
              data-handle="{{ product.handle }}"
            >
              Add Bundle
            </button>
          </div>
        {% endfor %}
      {% endif %}
    </div>

    <div class="product-variants-wrapper">
      {% if collection != blank %}
        {% for product in collection.products limit: 4 %}
          <div
            class="color-swatches"
            data-handle="{{ product.handle }}"
            {% unless forloop.first %}style="display:none;"{% endunless %}
          >
            {% for option in product.options_with_values %}
              {% if option.name == 'Color' %}
                {% for value in option.values %}
                  <span
                    class="color-item"
                    style="background-color: {{ value | replace: ' ', '' | downcase }};"
                    title="{{ value }}"
                  ></span>
                {% endfor %}
              {% endif %}
            {% endfor %}
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var section = document.querySelector('.custom-product-section');
    if (!section) return;

    var cards = section.querySelectorAll('.product-card');
    var swatchGroups = section.querySelectorAll('.color-swatches');

    function selectProduct(handle) {
      cards.forEach(function (card) {
        card.classList.toggle('is-active', card.dataset.handle === handle);
      });
      swatchGroups.forEach(function (group) {
        group.style.display = group.dataset.handle === handle ? '' : 'none';
      });
    }

    cards.forEach(function (card) {
      card.addEventListener('click', function (e) {
        var btn = e.target.closest('.select-product-btn');
        var link = e.target.closest('.link');

        if (btn) {
          // "Add Bundle" click selects the product instead of navigating
          e.preventDefault();
          selectProduct(card.dataset.handle);
        } else if (!link) {
          // clicking anywhere else on the card (not the image link) selects it
          selectProduct(card.dataset.handle);
        }
        // clicking the image link still navigates to the product page normally
      });
    });
  });
</script>

<style>
  .product-card {
    cursor: pointer;
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .product-card.is-active {
    outline: 2px solid #000; /* swap for your theme's accent color */
    outline-offset: 2px;
  }
  .color-swatches {
    display: flex;
    gap: 8px;
    margin-top: 16px;
  }
  .color-item {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    border: 1px solid rgba(0, 0, 0, 0.15);
    display: inline-block;
  }
</style>

{% schema %}
{
  "name": "Custom Product Section",
  "settings": [
    {
      "type": "collection",
      "id": "collection_one",
      "label": "Collection"
    }
  ],
  "presets": [
    {
      "name": "Custom Product Section"
    }
  ]
}
{% endschema %}