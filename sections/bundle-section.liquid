<div class="custom-product-section">
  <div class="container">
    <div class="product-grid">
      {% assign collection = section.settings.collection_one %}

      {% if collection != blank %}
        {% for product in collection.products limit: 4 %}
          <div class="product-card">
            <a href="{{product.url }}" class="link">
              <img
                src="{{ product.featured_image | image_url: width: 500 }}"
                alt="{{ product.title }}"
                width=""
                height=""
              >
            </a>
            <h4>{{ product.title }}</h4>
            <button class="button button--full-width button--secondary btn-bg-border">Add Bundle</button>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Bundle Product",
  "settings": [
    {
      "type": "collection",
      "id": "collection_one",
      "label": "Add First Collection"
    },
    {
      "type": "collection",
      "id": "collection_two",
      "label": "Add Two Collection"
    }
  ],
  "presets": [
    {
      "name": "Bundle Product"
    }
  ]
}
{% endschema %}

{% stylesheet %}
  /* =========================
    Custom Product Section
    ========================= */

    .custom-product-section {
        width: 100%;
    }

    .custom-product-section .container {
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        padding: 40px 15px;
    }

    .custom-product-section .product-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 15px;
        border: 1px solid #b39f97;
        padding: 15px 0;
        border-radius: 15px;
    }

    .custom-product-section .product-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }

    .custom-product-section .product-card img {
        display: block;
        width: 100%;
        height: auto;
        border-radius: 8px;
        object-fit: cover;
        width: 150px;
    }

    .custom-product-section .product-card h4 {
        margin: 16px 0 10px;
        font-size: 18px;
        font-weight: 600;
        line-height: 1.3;
        color: #222;
    }

    .custom-product-section .product-card p {
        margin: 0;
        font-size: 16px;
        line-height: 1.6;
        color: #666;
    }

    /* Tablet */
    @media (max-width: 991px) {
        .custom-product-section .product-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    /* Mobile */
    @media (max-width: 576px) {
        .custom-product-section .product-grid {
            grid-template-columns: 1fr;
            gap: 20px;
        }

        .custom-product-section .product-card h3 {
            font-size: 20px;
        }

        .custom-product-section .product-card p {
            font-size: 15px;
        }
    }
{% endstylesheet %}
