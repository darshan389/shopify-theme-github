<div class="custom-product-section">
  <div class="container">
    <div class="product-grid">
      {% assign collection = section.settings.collection_one %}

      {% if collection != blank %}
        {% for product in collection.products limit: 4 %}
          <div class="product-card{% if forloop.first %} is-active{% endif %}" data-handle="{{ product.handle }}">
              <img
                src="{{ product.featured_image | image_url: width: 500 }}"
                alt="{{ product.title }}"
                width=""
                height=""
              >
            <h4>{{ product.title }}</h4>
            <button
              type="button"
              class="button button--full-width button--secondary btn-bg-border select-product-btn"
              data-handle="{{ product.handle }}"
            >
              Add Bundle
            </button>
          </div>
        {% endfor %}
      {% endif %}
    </div>

    <div class="variant-picker">
      {% if collection != blank %}
        {% for product in collection.products limit: 4 %}
          <div
            class="color-swatches"
            data-handle="{{ product.handle }}"
            {% unless forloop.first %}style="display:none;"{% endunless %}
          >
            {% for option in product.options_with_values %}
              {% if option.name == 'Color' %}
                {% for value in option.values %}
                  <span
                    class="color-item"
                    style="background-color: {{ value }};"
                    title="{{ value }}"
                  ></span>
                {% endfor %}
              {% endif %}
            {% endfor %}
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Bundle Product",
  "settings": [
    {
      "type": "collection",
      "id": "collection_one",
      "label": "Add First Collection"
    },
    {
      "type": "collection",
      "id": "collection_two",
      "label": "Add Two Collection"
    }
  ],
  "presets": [
    {
      "name": "Bundle Product"
    }
  ]
}
{% endschema %}

{% stylesheet %}
      /* =========================
        Custom Product Section
        ========================= */

        .custom-product-section {
            width: 100%;
        }

        .custom-product-section .container {
            width: 100%;
            max-width: 1000px;
            margin: 0 auto;
            padding: 40px 15px;
        }

        .custom-product-section .product-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 15px;
            border-radius: 15px;
        }

        .custom-product-section .product-card {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            cursor: pointer;
        }

        .custom-product-section .product-card img {
            display: block;
            width: 100%;
            height: auto;
            border-radius: 8px;
            object-fit: cover;
            width: 150px;
        }

        .custom-product-section .product-card h4 {
            margin: 16px 0 10px;
            font-size: 16px;
            font-weight: 600;
            line-height: 1.3;
            color: #222;
        }

        .custom-product-section .product-card p {
            margin: 0;
            font-size: 16px;
            line-height: 1.6;
            color: #666;
        }

        .custom-product-section .product-card.is-active {
            outline: 2px solid #686868ff;
            outline-offset: 4px;
            border-radius: 8px;
        }

        /* Tablet */
        @media (max-width: 991px) {
            .custom-product-section .product-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        /* Mobile */
        @media (max-width: 576px) {
            .custom-product-section .product-grid {
                grid-template-columns: 1fr;
                gap: 20px;
            }

            .custom-product-section .product-card h3 {
                font-size: 20px;
            }

            .custom-product-section .product-card p {
                font-size: 15px;
            }
        }



        .color-item {
      display: inline-block;
      width: 30px;
      height: 30px;
      border: 1px solid #ddd;
      border-radius: 50%;
  }
        .variant-picker {
        margin-top: 20px;
    }

    .variant-picker__title {
        margin-bottom: 20px;
        font-size: 16px;
        font-weight: 600;
    }

    .variant-picker__list {
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
    }

    .variant-picker__item {
        cursor: pointer;
        text-align: center;
    }

    .variant-picker__item input {
        display: none;
    }

    .variant-picker__item img {
        display: block;
        width: 70px;
        height: 70px;
        object-fit: cover;
        border: 2px solid #ddd;
        transition: .3s;
    }

    .variant-picker__name {
        display: block;
        margin-top: 8px;
        font-size: 13px;
    }

    .variant-picker__item input:checked + img {
        border-color: #2da9ff;
        box-shadow: 0 0 0 2px #2da9ff;
    }

    .color-swatches {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }
{% endstylesheet %}

<script>
  document.addEventListener('DOMContentLoaded', function () {
  document.querySelectorAll('.custom-product-section').forEach(function (section) {
    var cards = section.querySelectorAll('.product-card');
    var swatchGroups = section.querySelectorAll('.color-swatches');

    function selectProduct(handle) {
      cards.forEach(function (card) {
        card.classList.toggle('is-active', card.dataset.handle === handle);
      });
      swatchGroups.forEach(function (group) {
        group.style.display = group.dataset.handle === handle ? '' : 'none';
      });
    }

    cards.forEach(function (card) {
      card.addEventListener('click', function (e) {
        var btn = e.target.closest('.select-product-btn');
        var link = e.target.closest('.link');

        if (btn) {
          // "Add Bundle" click selects instead of navigating
          e.preventDefault();
          selectProduct(card.dataset.handle);
        } else if (!link) {
          // clicking card area (not the image link) selects it
          selectProduct(card.dataset.handle);
        }
        // clicking the product image link still navigates normally
      });
    });
  });
});
</script>