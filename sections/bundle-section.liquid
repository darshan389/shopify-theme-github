<div class="custom-product-section">
    <div class="container">
        <div class="product-grid">

            <div class="product-card">
                <img src="https://via.placeholder.com/280x280" alt="Product 1">
                <h3>Product Title 1</h3>
                <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
            </div>

        </div>
    </div>
</div>

{% schema %}
{
    "name": "Bundle Product",
    "settings": [
        {
            "type": "collection",
            "id": "collection_one",
            "label": "Add First Collection"
        },
        {
            "type": "collection",
            "id": "collection_two",
            "label": "Add Two Collection"
        },
    ],
    "presets": [
        {
            "name": "Bundle Product"
        }
    ]
}
{% endschema %}

{% stylesheet %}
  /* =========================
    Custom Product Section
    ========================= */

    .custom-product-section {
        width: 100%;
    }

    .custom-product-section .container {
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        padding: 40px 15px;
    }

    .custom-product-section .product-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 30px;
    }

    .custom-product-section .product-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }

    .custom-product-section .product-card img {
        display: block;
        width: 100%;
        height: auto;
        border-radius: 8px;
        object-fit: cover;
    }

    .custom-product-section .product-card h3 {
        margin: 16px 0 10px;
        font-size: 22px;
        font-weight: 600;
        line-height: 1.3;
        color: #222;
    }

    .custom-product-section .product-card p {
        margin: 0;
        font-size: 16px;
        line-height: 1.6;
        color: #666;
    }

    /* Tablet */
    @media (max-width: 991px) {
        .custom-product-section .product-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    /* Mobile */
    @media (max-width: 576px) {
        .custom-product-section .product-grid {
            grid-template-columns: 1fr;
            gap: 20px;
        }

        .custom-product-section .product-card h3 {
            font-size: 20px;
        }

        .custom-product-section .product-card p {
            font-size: 15px;
        }
    }
{% endstylesheet %}