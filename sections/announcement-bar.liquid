{% if section.settings.section_title != blank %}
  <div class="announcement-bar">
    <div class="container">
      <div class="anc-inner">
        {% render 'icons', icon: 'small_heart_icon' %}
        <span>{{ section.settings.section_title }}</span>
        {% render 'icons', icon: 'small_heart_icon' %}
        <div class="close-icon">
          {% render 'icons', icon: 'close_icon' %}
        </div>
      </div>
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "section_title",
      "label": "Title"
    },
    {
      "type": "color_background",
      "id": "section_bg_color",
      "label": "Background"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}

{% style %}
  .announcement-bar{
    background:{{ section.settings.section_bg_color }};
  }
{% endstyle %}
