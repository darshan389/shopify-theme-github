{% style %}
    .cart-items-container {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .cart-item {
    display: grid;
        grid-template-columns: 100px 8fr 250px 165px 186px;
    gap: 15px;
    align-items: center;
    border-bottom: 1px solid #ddd;
    padding-bottom: 15px;
  }

  .cart-item__image img {
    max-width: 100%;
    height: auto;
  }

  .cart-item__details h3 {
    margin: 0 0 5px;
    font-size: 16px;
  }

  .cart-item__price {
    font-weight: bold;
  }

  .cart-item__quantity input {
    padding: 5px;
  }

  .cart-item__remove a {
    color: #d9534f;
    text-decoration: none;
  }
{% endstyle %}
